#!/usr/bin/env bash
set -euo pipefail

msvc_wine_root='@MSVC_WINE_ROOT@'
source "$msvc_wine_root/bin/x86/msvcenv.sh"

# Some msvc-wine installations produce root-relative WINEPATH entries. Add
# Wine's Z: drive prefix so link.exe can spawn tools such as rc.exe.
IFS=';' read -r -a wine_paths <<< "$WINEPATH"
for i in "${!wine_paths[@]}"; do
    if [[ "${wine_paths[$i]}" == \\* ]]; then
        wine_paths[$i]="z:${wine_paths[$i]}"
    fi
done
WINEPATH=$(IFS=';'; printf '%s' "${wine_paths[*]}")
export WINEPATH

exec "$msvc_wine_root/bin/x86/wine-msvc.sh" "$BINDIR/link.exe" "$@"
